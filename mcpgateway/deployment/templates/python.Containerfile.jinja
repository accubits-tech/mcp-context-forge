# syntax=docker/dockerfile:1
# Rendered by mcpgateway.services.deployment.templates — do not edit by hand.
# TODO(deploy): pin base image by @sha256 via mcpgateway_deploy_base_image_python in production.
FROM {{ base_image }}

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

# System packages required by common MCP servers and our runtime bridge:
#   - git: GitPython does an eager refresh on import; without it servers like
#     mcp-server-git crash before producing any output.
RUN apt-get update && apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

# Non-root user UID:GID 10001:10001; the container also runs with --user 10001:10001.
RUN groupadd --system --gid 10001 app && \
    useradd  --system --uid 10001 --gid 10001 --home-dir /app --shell /usr/sbin/nologin app && \
    mkdir -p /app && chown -R 10001:10001 /app

WORKDIR /app
COPY --chown=10001:10001 . /app/

# Install the project + its deps so `python -m <pkg>` works at runtime.
# System install (not a .venv) keeps PATH simple and avoids multi-stage complexity;
# the container is single-purpose and short-lived, so a venv adds no value here.
# TODO(deploy): honour uv.lock for reproducible builds once we multi-stage.
RUN set -eu; \
    pip install --upgrade pip setuptools wheel; \
    if [ -f requirements.txt ]; then \
        pip install -r requirements.txt; \
    fi; \
    if [ -f pyproject.toml ] || [ -f setup.py ]; then \
        pip install .; \
    elif [ ! -f requirements.txt ]; then \
        echo "no pyproject.toml / setup.py / requirements.txt found" >&2; exit 1; \
    fi

{% if entry_mode == "stdio" %}
# Stdio entry mode: install the gateway's translate module so we can bridge stdio <-> HTTP.
# cryptography is constrained below 47 because the 47.x/48.x prebuilt wheels SIGILL on
# import under some virtualized arm64 hosts (e.g. Docker Desktop on Apple Silicon).
# 46.x satisfies mcp-contextforge-gateway's >=46.0.3 requirement.
RUN pip install 'cryptography>=46.0.3,<47' mcp-contextforge-gateway
{% endif %}

ENV PORT=8080 \
    MCP_DEPLOY_TOKEN=__INJECTED_AT_RUN__ \
    HOME=/tmp

USER 10001:10001
EXPOSE 8080

{% if entry_mode == "stdio" %}
CMD ["python", "-m", "mcpgateway.translate", "--stdio", "{{ entry_command }}", "--port", "8080", "--host", "0.0.0.0", "--expose-streamable-http"]
{% else %}
# HTTP entry mode: user command must listen on $PORT (8080).
CMD {{ entry_command_argv | tojson }}
{% endif %}
